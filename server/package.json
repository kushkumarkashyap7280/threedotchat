{
  "name": "chat-backend-root",
  "private": true,
  "packageManager": "yarn@4.17.1",
  "workspaces": [
    "services/*",
    "packages/*"
  ],
  "scripts": {
    "dev": "yarn workspaces foreach -A -pi run dev",
    "build": "yarn workspaces foreach -A -pt run build",
    "lint": "eslint 'services/**/*.ts' 'packages/**/*.ts'",
    "format": "prettier --write 'services/**/*.ts' 'packages/**/*.ts'"
  },
  "devDependencies": {
    "@types/node": "^26.1.1",
    "eslint": "^10.7.0",
    "eslint-config-prettier": "^10.1.8",
    "prettier": "^3.9.5",
    "tsx": "^4.23.1",
    "typescript": "^7.0.2",
    "typescript-eslint": "^8.63.0"
  }
}
